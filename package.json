{
  "name": "@jpahd/chatworks",
  "version": "0.3.0",
  "description": "Drop-in chat surface — Lit web components, a Connect-RPC transport layer, model-catalog discovery, slash-command engine, markdown + Shiki rendering, and a runtime settings panel — for embedding an LLM chat into any web app.",
  "license": "MIT",
  "author": "Paul Derscheid",
  "type": "module",
  "sideEffects": [
    "./dist/components/*.js",
    "./dist/components/**/*.js",
    "./dist/index.js",
    "./dist/lib/events.js"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./chat-view": {
      "types": "./dist/components/chat-view.d.ts",
      "import": "./dist/components/chat-view.js"
    },
    "./settings-panel": {
      "types": "./dist/components/settings-panel.d.ts",
      "import": "./dist/components/settings-panel.js"
    },
    "./toast": {
      "types": "./dist/components/toast.d.ts",
      "import": "./dist/components/toast.js"
    },
    "./loading-indicator": {
      "types": "./dist/components/loading-indicator.d.ts",
      "import": "./dist/components/loading-indicator.js"
    },
    "./combobox": {
      "types": "./dist/components/combobox.d.ts",
      "import": "./dist/components/combobox.js"
    },
    "./host": {
      "types": "./dist/host.d.ts",
      "import": "./dist/host.js"
    },
    "./chunk": {
      "types": "./dist/lib/chunk.d.ts",
      "import": "./dist/lib/chunk.js"
    },
    "./adapters/connect-rpc": {
      "types": "./dist/adapters/connect-rpc.d.ts",
      "import": "./dist/adapters/connect-rpc.js"
    },
    "./transport": {
      "types": "./dist/lib/transport.d.ts",
      "import": "./dist/lib/transport.js"
    },
    "./settings": {
      "types": "./dist/lib/settings.d.ts",
      "import": "./dist/lib/settings.js"
    },
    "./events": {
      "types": "./dist/lib/events.d.ts",
      "import": "./dist/lib/events.js"
    },
    "./focus": {
      "types": "./dist/lib/focus.d.ts",
      "import": "./dist/lib/focus.js"
    },
    "./catalog": {
      "types": "./dist/lib/catalog.d.ts",
      "import": "./dist/lib/catalog.js"
    },
    "./chat-types": {
      "types": "./dist/lib/chat-types.d.ts",
      "import": "./dist/lib/chat-types.js"
    },
    "./markdown": {
      "types": "./dist/lib/markdown.d.ts",
      "import": "./dist/lib/markdown.js"
    },
    "./highlight": {
      "types": "./dist/lib/highlight.d.ts",
      "import": "./dist/lib/highlight.js"
    },
    "./clipboard": {
      "types": "./dist/lib/clipboard.d.ts",
      "import": "./dist/lib/clipboard.js"
    },
    "./slash": {
      "types": "./dist/lib/slash.d.ts",
      "import": "./dist/lib/slash.js"
    },
    "./attachments": {
      "types": "./dist/lib/attachments.d.ts",
      "import": "./dist/lib/attachments.js"
    },
    "./proto/auth": {
      "types": "./dist/gen/gitchat/v1/auth_pb.d.ts",
      "import": "./dist/gen/gitchat/v1/auth_pb.js"
    },
    "./proto/chat": {
      "types": "./dist/gen/gitchat/v1/chat_pb.d.ts",
      "import": "./dist/gen/gitchat/v1/chat_pb.js"
    },
    "./proto/repo": {
      "types": "./dist/gen/gitchat/v1/repo_pb.d.ts",
      "import": "./dist/gen/gitchat/v1/repo_pb.js"
    }
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "build:watch": "tsc -w -p tsconfig.build.json",
    "test": "bun test src/",
    "lint": "oxlint -c oxlintrc.json src/",
    "fmt": "oxfmt --write src/",
    "fmt:check": "oxfmt --check src/",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@lit/context": "^1.1.3",
    "lit": "^3.2.1"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "marked": "^18.0.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@happy-dom/global-registrator": "^20.9.0",
    "@lit/context": "^1.1.3",
    "@types/dompurify": "^3.2.0",
    "bun-types": "^1.2.0",
    "lit": "^3.2.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.7.2"
  }
}
